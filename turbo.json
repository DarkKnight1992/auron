{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "docgen": {
      "dependsOn": ["^build"],
      "outputs": ["apps/docs/.vitepress/data/components.json"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "*.d.ts", ".vitepress/dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": [],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
