{
  "extends": "@auron/standard/tsconfig/vue",
  "compilerOptions": {
    "types": ["node"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,
    "paths": {
      "reka-ui/dist/index2": ["./node_modules/reka-ui/dist/index2.d.ts"],
      "reka-ui/dist/index3": ["./node_modules/reka-ui/dist/index3.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["dist", "node_modules", "src/style-smoke-test.ts"]
}
